{
  "version": "1.0.0",
  "persona_preset": "bmad",
  "platform": {
    "org": "semspec",
    "id": "semspec-e2e-hybrid",
    "environment": "test"
  },
  "nats": {
    "urls": [
      "nats://nats:4222"
    ],
    "max_reconnects": -1,
    "reconnect_wait": "2s",
    "jetstream": {
      "enabled": true
    }
  },
  "model_registry": {
    "endpoints": {
      "gemini-flash": {
        "provider": "gemini",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-3-flash-preview",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": true,
        "tool_format": "openai",
        "stream": false,
        "reasoning_effort": "low",
        "request_timeout": "120s",
        "wire_backend": "wire"
      },
      "gemini-flash-lite": {
        "provider": "gemini",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-3.1-flash-lite",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": false,
        "stream": false,
        "request_timeout": "60s",
        "wire_backend": "wire"
      },
      "gemini-pro": {
        "provider": "gemini",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-3.1-pro-preview",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": true,
        "tool_format": "openai",
        "stream": false,
        "reasoning_effort": "medium",
        "request_timeout": "900s",
        "wire_backend": "wire"
      },
      "claude-sonnet": {
        "provider": "anthropic",
        "url": "https://api.anthropic.com/v1",
        "model": "claude-sonnet-4-6",
        "api_key_env": "ANTHROPIC_API_KEY",
        "max_tokens": 200000,
        "supports_tools": true,
        "reasoning_effort": "low",
        "max_concurrent": 10,
        "requests_per_minute": 100,
        "request_timeout": "120s"
      },
      "semembed": {
        "provider": "openai",
        "url": "http://semembed:8081/v1",
        "model": "Snowflake/snowflake-arctic-embed-s",
        "max_tokens": 0,
        "disable_keepalives": true
      },
      "seminstruct-fast": {
        "provider": "openai",
        "url": "http://seminstruct-fast:8083/v1",
        "model": "qwen3-0.6b",
        "max_tokens": 4096,
        "max_output_tokens": 512,
        "supports_tools": false,
        "stream": false,
        "request_timeout": "15s",
        "disable_keepalives": true
      },
      "seminstruct-answer": {
        "provider": "openai",
        "url": "http://seminstruct-answer:8083/v1",
        "model": "qwen3-1.7b",
        "max_tokens": 16384,
        "max_output_tokens": 1024,
        "supports_tools": false,
        "stream": false,
        "request_timeout": "30s",
        "disable_keepalives": true
      },
      "seminstruct-summary": {
        "provider": "openai",
        "url": "http://seminstruct-summary:8083/v1",
        "model": "qwen3-8b",
        "max_tokens": 16384,
        "max_output_tokens": 4096,
        "supports_tools": false,
        "stream": false,
        "request_timeout": "180s",
        "disable_keepalives": true
      }
    },
    "capabilities": {
      "planning": {
        "description": "Plan generation and high-level reasoning",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "claude-sonnet",
          "gemini-flash"
        ]
      },
      "writing": {
        "description": "Documentation, plans, specifications",
        "preferred": [
          "gemini-flash"
        ],
        "fallback": [
          "gemini-pro"
        ]
      },
      "research": {
        "description": "Single-shot upstream-API-surface investigation for the developer's research() tool. Reads source/docs/specs in its own context window, distills into an answer + citations capped at 4 KiB. Flash is the right tier: bulk reads + structured summary, no deep reasoning required. Pro fallback for cases where flash truncates too aggressively. See project_research_tool_plan_2026_05_14.",
        "preferred": [
          "gemini-flash"
        ],
        "fallback": [
          "gemini-pro"
        ]
      },
      "coding": {
        "description": "Code generation, implementation — Sonnet's strength",
        "preferred": [
          "claude-sonnet"
        ],
        "fallback": [
          "gemini-pro",
          "gemini-flash"
        ]
      },
      "reviewing": {
        "description": "Code review, quality analysis — Sonnet's strength",
        "preferred": [
          "claude-sonnet"
        ],
        "fallback": [
          "gemini-pro",
          "gemini-flash"
        ]
      },
      "requirement_generation": {
        "description": "Requirement decomposition — partitioning a plan into reqs with non-overlapping file ownership + chain-dep DAG. Decomposition reasoning closer to architecture than to writing; gemini-flash variance (2 vs 4 reqs across runs 2026-05-05) confirms mid-tier is too thin. Pro preferred, flash fallback.",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "gemini-flash"
        ]
      },
      "scenario_generation": {
        "description": "BDD scenario generation",
        "preferred": [
          "gemini-flash"
        ],
        "fallback": [
          "gemini-pro"
        ]
      },
      "plan_review": {
        "description": "SOP-aware plan review",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "claude-sonnet",
          "gemini-flash"
        ]
      },
      "architecture": {
        "description": "Architecture generation — technology choices, component boundaries, data flow",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "claude-sonnet",
          "gemini-flash"
        ]
      },
      "qa": {
        "description": "Rollup quality review",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "claude-sonnet",
          "gemini-flash"
        ]
      },
      "lesson_decomposition": {
        "description": "ADR-033 lesson decomposer — rare, benefits from a smarter model",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "claude-sonnet",
          "gemini-flash"
        ]
      },
      "fast": {
        "description": "Quick responses, classification",
        "preferred": [
          "gemini-flash"
        ]
      },
      "embedding": {
        "description": "Vector embeddings for graph entities (HTTP /v1/embeddings, NOT chat)",
        "preferred": [
          "semembed"
        ]
      },
      "query_classification": {
        "description": "graph-query T3 fallback classifier — small JSON output, latency-critical",
        "preferred": [
          "seminstruct-fast"
        ],
        "timeout": "10s"
      },
      "answer_synthesis": {
        "description": "graph-query globalSearch answer composition — ephemeral, agent reads once. 1.7B at ~25 tok/s gives sub-3s answers; quality solid because the path is extractive over supplied community summaries.",
        "preferred": [
          "seminstruct-answer"
        ],
        "timeout": "30s"
      },
      "community_summary": {
        "description": "graph-clustering community summarization — background batch, persisted into graph. seminstruct-8B-on-CPU validated 2026-05-06 ADR-036 Phase 2 to be too slow at any scale beyond toy fixtures (>180s per community on 2 CPUs). gemini-flash-lite gives sub-second response and Google's quality bar exceeds the MS GraphRAG sub-7B floor anyway. Local seminstruct-summary kept as fallback for offline/quota scenarios.",
        "preferred": [
          "gemini-flash-lite"
        ],
        "fallback": [
          "seminstruct-summary"
        ],
        "timeout": "60s"
      },
      "question_answering": {
        "description": "Answerer-agent backend for ask_question routes — bigger reasoning model than workflow default.",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "claude-sonnet",
          "gemini-flash"
        ],
        "timeout": "60s"
      },
      "task_decomposition": {
        "description": "requirement-executor decomposer — DAG of executable nodes from a requirement. Planner-class reasoning, not coder-class generation.",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "claude-sonnet"
        ]
      }
    },
    "defaults": {
      "model": "gemini-flash"
    }
  },
  "services": {
    "service-manager": {
      "name": "service-manager",
      "enabled": true,
      "config": {
        "http_port": 8080
      }
    },
    "component-manager": {
      "name": "component-manager",
      "enabled": true,
      "config": {}
    },
    "heartbeat": {
      "name": "heartbeat",
      "enabled": false,
      "config": {}
    },
    "message-logger": {
      "name": "message-logger",
      "enabled": true,
      "config": {
        "buffer_size": 10000,
        "monitor_subjects": [
          "user.>",
          "agent.>",
          "tool.>",
          "graph.>",
          "workflow.>",
          "source.>",
          "context.>"
        ]
      }
    }
  },
  "components": {
    "agentic-dispatch": {
      "name": "agentic-dispatch",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_role": "general",
        "default_model": "gemini-flash",
        "auto_continue": false,
        "stream_name": "USER",
        "permissions": {
          "view": [
            "*"
          ],
          "submit_task": [
            "*"
          ],
          "cancel_own": true,
          "cancel_any": [
            "admin"
          ],
          "approve": [
            "*"
          ]
        }
      }
    },
    "agentic-loop": {
      "name": "agentic-loop",
      "type": "processor",
      "enabled": true,
      "config": {
        "max_iterations": 80,
        "timeout": "900s",
        "stream_name": "AGENT",
        "loops_bucket": "AGENT_LOOPS",
        "content_bucket": "AGENT_CONTENT",
        "tool_call_governance": {
          "mode": "enforce",
          "timeout": "1s"
        }
      }
    },
    "agentic-model": {
      "name": "agentic-model",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "timeout": "900s"
      }
    },
    "agentic-tools": {
      "name": "agentic-tools",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "consumer_name_suffix": "semspec-e2e",
        "timeout": "180s"
      }
    },
    "rule-processor": {
      "name": "rule-processor",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "rule_toolcall_proposed_in",
              "subject": "agent.toolcall.proposed.>",
              "type": "jetstream",
              "stream_name": "AGENT",
              "description": "ADR-039 proposed tool calls awaiting governance verdict"
            }
          ],
          "outputs": [
            {
              "name": "toolcall_approved_out",
              "subject": "agent.toolcall.approved.>",
              "type": "jetstream",
              "stream_name": "AGENT",
              "description": "ADR-039 approve verdicts to agentic-loop (loop_id.call_id subject shape per migration doc)"
            },
            {
              "name": "toolcall_rejected_out",
              "subject": "agent.toolcall.rejected.>",
              "type": "jetstream",
              "stream_name": "AGENT",
              "description": "ADR-039 reject verdicts to agentic-loop (loop_id.call_id subject shape per migration doc)"
            }
          ]
        },
        "inline_rules": [
          {
            "id": "tool-call-governance",
            "type": "expression",
            "name": "Tool-call governance — race-free worktree-leak deny + default approve",
            "description": "Single consolidated rule per semstreams beta.72 / ADR-041 unified evaluator. Fires on every proposed tool call (rule-level condition is a tautological non-empty check on $message.tool_name). Each worktree-leak pattern's publish+deny pair is gated by per-action When clauses on $message.tool_name and $message.command. When a deny action fires, stateful_evaluator short-circuits the remaining actions per its 'break on ErrDenyVerdict' contract, so the unconditional approve at the end only publishes when no deny matched. Race-free in enforce mode — exactly one verdict per call_id, no Go-map-iteration order race. Replaces three sibling rules from beta.71 (block-bash-cd-workspace, block-bash-redirect-workspace, block-bash-tee-workspace) which raced under map iteration when more than one matched (or did not match) the same call.",
            "enabled": true,
            "conditions": [
              {"field": "$message.tool_name", "operator": "ne", "value": "", "required": false}
            ],
            "logic": "and",
            "on_enter": [
              {
                "type": "publish",
                "when": [
                  {"field": "$message.tool_name", "operator": "eq", "value": "bash"},
                  {"field": "$message.command", "operator": "regex", "value": "cd /workspace(\\s|$|[;&|])"}
                ],
                "subject": "agent.toolcall.rejected.$message.loop_id.$message.call_id",
                "properties": {
                  "decision": "rejected",
                  "call_id": "$message.call_id",
                  "reason": "bash 'cd /workspace' blocked — stay in worktree"
                }
              },
              {
                "type": "deny",
                "when": [
                  {"field": "$message.tool_name", "operator": "eq", "value": "bash"},
                  {"field": "$message.command", "operator": "regex", "value": "cd /workspace(\\s|$|[;&|])"}
                ],
                "reason": "bash 'cd /workspace' blocked — stay in worktree"
              },
              {
                "type": "publish",
                "when": [
                  {"field": "$message.tool_name", "operator": "eq", "value": "bash"},
                  {"field": "$message.command", "operator": "contains", "value": "> /workspace/"}
                ],
                "subject": "agent.toolcall.rejected.$message.loop_id.$message.call_id",
                "properties": {
                  "decision": "rejected",
                  "call_id": "$message.call_id",
                  "reason": "bash redirect into /workspace/ blocked — write to worktree path"
                }
              },
              {
                "type": "deny",
                "when": [
                  {"field": "$message.tool_name", "operator": "eq", "value": "bash"},
                  {"field": "$message.command", "operator": "contains", "value": "> /workspace/"}
                ],
                "reason": "bash redirect into /workspace/ blocked — write to worktree path"
              },
              {
                "type": "publish",
                "when": [
                  {"field": "$message.tool_name", "operator": "eq", "value": "bash"},
                  {"field": "$message.command", "operator": "contains", "value": "tee /workspace/"}
                ],
                "subject": "agent.toolcall.rejected.$message.loop_id.$message.call_id",
                "properties": {
                  "decision": "rejected",
                  "call_id": "$message.call_id",
                  "reason": "bash 'tee /workspace/' blocked — write to worktree path"
                }
              },
              {
                "type": "deny",
                "when": [
                  {"field": "$message.tool_name", "operator": "eq", "value": "bash"},
                  {"field": "$message.command", "operator": "contains", "value": "tee /workspace/"}
                ],
                "reason": "bash 'tee /workspace/' blocked — write to worktree path"
              },
              {
                "type": "publish",
                "subject": "agent.toolcall.approved.$message.loop_id.$message.call_id",
                "properties": {
                  "decision": "approved",
                  "call_id": "$message.call_id"
                }
              }
            ],
            "metadata": {
              "category": "governance",
              "tier": 0,
              "adr": "041"
            }
          }
        ]
      }
    },
    "graph-ingest": {
      "name": "graph-ingest",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entities_in",
              "subject": "graph.ingest.entity",
              "type": "jetstream",
              "stream_name": "GRAPH"
            }
          ],
          "outputs": [
            {
              "name": "entity_states",
              "subject": "ENTITY_STATES",
              "type": "kv-write"
            }
          ]
        },
        "enable_hierarchy": true
      }
    },
    "graph-index": {
      "name": "graph-index",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entity_watch",
              "subject": "ENTITY_STATES",
              "type": "kv-watch"
            }
          ],
          "outputs": [
            {
              "name": "outgoing_index",
              "subject": "OUTGOING_INDEX",
              "type": "kv"
            },
            {
              "name": "incoming_index",
              "subject": "INCOMING_INDEX",
              "type": "kv"
            },
            {
              "name": "alias_index",
              "subject": "ALIAS_INDEX",
              "type": "kv"
            },
            {
              "name": "predicate_index",
              "subject": "PREDICATE_INDEX",
              "type": "kv"
            }
          ]
        },
        "workers": 4,
        "batch_size": 50,
        "coalesce_ms": 100
      }
    },
    "graph-embedding": {
      "name": "graph-embedding",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entity_watch",
              "subject": "ENTITY_STATES",
              "type": "kv-watch"
            }
          ],
          "outputs": [
            {
              "name": "embeddings",
              "subject": "EMBEDDINGS_CACHE",
              "type": "kv"
            }
          ]
        },
        "embedder_type": "http",
        "batch_size": 50,
        "cache_ttl": "1h",
        "coalesce_ms": 200,
        "text_suffixes": [
          ".content",
          ".summary",
          ".description",
          ".title",
          ".name",
          ".goal",
          ".context",
          ".issue",
          ".suggestion",
          ".source_code",
          ".signature",
          ".body",
          ".comment"
        ]
      }
    },
    "graph-query": {
      "name": "graph-query",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "query_requests",
              "subject": "graph.query.>",
              "type": "nats-request"
            }
          ],
          "outputs": []
        },
        "request_timeout": "60s",
        "max_traversal_depth": 5,
        "max_traversal_nodes": 100
      }
    },
    "graph-gateway": {
      "name": "graph-gateway",
      "type": "gateway",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "http",
              "subject": ":8082",
              "type": "http"
            }
          ],
          "outputs": [
            {
              "name": "mutations",
              "subject": "graph.mutation.*",
              "type": "nats-request"
            }
          ]
        },
        "graphql_path": "/graphql",
        "mcp_path": "/mcp",
        "bind_address": ":8082",
        "enable_playground": true
      }
    },
    "planner": {
      "name": "planner",
      "type": "processor",
      "enabled": true,
      "config": {
        "max_generation_retries": 2,
        "sandbox_url": "http://sandbox:8090"
      }
    },
    "requirement-generator": {
      "name": "requirement-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_capability": "requirement_generation",
        "sandbox_url": "http://sandbox:8090"
      }
    },
    "scenario-generator": {
      "name": "scenario-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_capability": "scenario_generation"
      }
    },
    "architecture-generator": {
      "name": "architecture-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_capability": "architecture"
      }
    },
    "plan-manager": {
      "name": "plan-manager",
      "type": "processor",
      "enabled": true,
      "config": {
        "execution_bucket_name": "EXECUTION_STATES",
        "max_concurrent_planners": 3,
        "max_review_iterations": 3,
        "auto_approve": false,
        "default_capability": "planning",
        "auto_reject_on_exhaustion": true,
        "sandbox_url": "http://sandbox:8090"
      }
    },
    "plan-reviewer": {
      "name": "plan-reviewer",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_capability": "plan_review",
        "auto_approve": false,
        "sandbox_url": "http://sandbox:8090"
      }
    },
    "project-manager": {
      "name": "project-manager",
      "type": "processor",
      "enabled": true,
      "config": {
        "repo_path": "/workspace",
        "sandbox_url": "http://sandbox:8090"
      }
    },
    "scenario-orchestrator": {
      "name": "scenario-orchestrator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "scenario-orchestrator",
        "trigger_subject": "scenario.orchestrate.*",
        "execution_timeout": "3600s"
      }
    },
    "question-manager": {
      "name": "question-manager",
      "type": "processor",
      "enabled": true,
      "config": {}
    },
    "researcher-manager": {
      "name": "researcher-manager",
      "type": "processor",
      "enabled": true,
      "config": {}
    },
    "requirement-executor": {
      "name": "requirement-executor",
      "type": "processor",
      "enabled": true,
      "config": {
        "timeout_seconds": 3600,
        "sandbox_url": "http://sandbox:8090",
        "max_requirement_retries": 2,
        "max_decomposer_retries": 2,
        "defer_terminal_on_recovery": true,
        "recovery_timeout_seconds": 60,
        "max_recovery_restarts": 1
      }
    },
    "structural-validator": {
      "name": "structural-validator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "structural-validator",
        "repo_path": "/workspace",
        "checklist_path": ".semspec/checklist.json",
        "default_timeout": "900s",
        "sandbox_url": "http://sandbox:8090"
      }
    },
    "execution-manager": {
      "name": "execution-manager",
      "type": "processor",
      "enabled": true,
      "config": {
        "max_tdd_cycles": 5,
        "timeout_seconds": 3600,
        "sandbox_url": "http://sandbox:8090",
        "graph_gateway_url": "http://localhost:8082",
        "indexing_budget": "60s",
        "enable_positive_lessons": true
      }
    },
    "workflow-documents": {
      "name": "workflow-documents",
      "type": "output",
      "enabled": true,
      "config": {
        "plan_state_bucket": "PLAN_STATES"
      }
    },
    "plan-decision-handler": {
      "name": "plan-decision-handler",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "plan-decision-handler",
        "trigger_subject": "workflow.trigger.plan-decision-cascade",
        "accepted_subject": "workflow.events.plan-decision.accepted",
        "auto_accept_recovery": true,
        "timeout_seconds": 120,
        "ports": {
          "inputs": [
            {
              "name": "cascade-triggers",
              "subject": "workflow.trigger.plan-decision-cascade",
              "type": "jetstream",
              "stream_name": "WORKFLOW",
              "description": "Receive cascade requests when a ChangeProposal is accepted",
              "required": true
            }
          ],
          "outputs": [
            {
              "name": "accepted-events",
              "subject": "workflow.events.plan-decision.accepted",
              "type": "jetstream",
              "stream_name": "WORKFLOW",
              "description": "Publish accepted event with cascade summary"
            },
            {
              "name": "cancellation-signals",
              "subject": "agent.signal.cancel.*",
              "type": "nats",
              "description": "Cancel running scenario loops affected by cascade"
            }
          ]
        }
      }
    },
    "qa-reviewer": {
      "name": "qa-reviewer",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_capability": "qa"
      }
    },
    "lesson-decomposer": {
      "name": "lesson-decomposer",
      "type": "processor",
      "enabled": true,
      "config": {
        "enabled": true,
        "stream_name": "WORKFLOW",
        "consumer_name": "lesson-decomposer",
        "filter_subject": "workflow.events.lesson.decompose.requested.>"
      }
    },
    "lesson-curator": {
      "name": "lesson-curator",
      "type": "processor",
      "enabled": true,
      "config": {
        "enabled": true,
        "sweep_interval": "24h",
        "idle_threshold": "720h",
        "min_age_before_retire": "168h"
      }
    },
    "recovery-agent": {
      "name": "recovery-agent",
      "type": "processor",
      "enabled": true,
      "config": {
        "enabled": true,
        "stream_name": "WORKFLOW",
        "consumer_name": "recovery-agent",
        "filter_subject": "recovery.requested.>",
        "trajectory_step_limit": 80
      }
    },
    "graph-clustering": {
      "name": "graph-clustering",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entity_watch",
              "subject": "ENTITY_STATES",
              "type": "kv-watch",
              "description": "Watch entity state changes for batch trigger"
            }
          ],
          "outputs": [
            {
              "name": "communities",
              "subject": "COMMUNITY_INDEX",
              "type": "kv",
              "description": "Community detection results"
            }
          ]
        },
        "detection_interval": "30s",
        "batch_size": 100,
        "enable_llm": true,
        "min_community_size": 2,
        "max_iterations": 100,
        "enable_structural": true,
        "pivot_count": 16,
        "max_hop_distance": 10,
        "enable_anomaly_detection": true,
        "anomaly_config": {
          "enabled": true,
          "max_anomalies_per_run": 100,
          "core_anomaly": {
            "enabled": true,
            "min_core_level": 2
          },
          "semantic_gap": {
            "enabled": true,
            "similarity_threshold": 0.7,
            "min_structural_distance": 3
          },
          "virtual_edges": {
            "auto_apply": {
              "enabled": true,
              "min_confidence": 0.95,
              "predicate_template": "inferred.semantic.{band}"
            },
            "review_queue": {
              "enabled": true,
              "min_confidence": 0.7,
              "max_confidence": 0.95,
              "require_llm_classification": false
            }
          }
        }
      }
    }
  },
