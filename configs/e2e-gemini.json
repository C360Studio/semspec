{
  "version": "1.0.2",
  "persona_preset": "bmad",
  "platform": {
    "org": "semspec",
    "id": "semspec-e2e-gemini",
    "environment": "test"
  },
  "nats": {
    "urls": [
      "nats://nats:4222"
    ],
    "max_reconnects": -1,
    "reconnect_wait": "2s",
    "jetstream": {
      "enabled": true
    }
  },
  "model_registry": {
    "endpoints": {
      "gemini-flash": {
        "provider": "openai",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-2.5-flash",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": true,
        "tool_format": "openai",
        "stream": false,
        "reasoning_effort": "low",
        "request_timeout": "120s"
      },
      "gemini-flash-lite": {
        "provider": "openai",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-2.5-flash-lite",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": false,
        "stream": false,
        "request_timeout": "60s"
      },
      "gemini-pro": {
        "provider": "openai",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-2.5-pro",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": true,
        "tool_format": "openai",
        "stream": false,
        "reasoning_effort": "low",
        "request_timeout": "180s"
      },
      "semembed": {
        "provider": "openai",
        "url": "http://semembed:8081/v1",
        "model": "Snowflake/snowflake-arctic-embed-s",
        "max_tokens": 0,
        "disable_keepalives": true
      },
      "seminstruct-fast": {
        "provider": "openai",
        "url": "http://seminstruct-fast:8083/v1",
        "model": "qwen3-0.6b",
        "max_tokens": 4096,
        "max_output_tokens": 512,
        "supports_tools": false,
        "stream": false,
        "request_timeout": "15s",
        "disable_keepalives": true
      },
      "seminstruct-answer": {
        "provider": "openai",
        "url": "http://seminstruct-answer:8083/v1",
        "model": "qwen3-1.7b",
        "max_tokens": 16384,
        "max_output_tokens": 1024,
        "supports_tools": false,
        "stream": false,
        "request_timeout": "30s",
        "disable_keepalives": true
      },
      "seminstruct-summary": {
        "provider": "openai",
        "url": "http://seminstruct-summary:8083/v1",
        "model": "qwen3-8b",
        "max_tokens": 16384,
        "max_output_tokens": 4096,
        "supports_tools": false,
        "stream": false,
        "request_timeout": "180s",
        "disable_keepalives": true
      }
    },
    "capabilities": {
      "planning": {
        "description": "Plan generation and architecture",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "gemini-flash"
        ]
      },
      "writing": {
        "description": "Documentation, plans, specifications",
        "preferred": [
          "gemini-flash"
        ]
      },
      "coding": {
        "description": "Code generation, implementation",
        "preferred": [
          "gemini-flash"
        ]
      },
      "reviewing": {
        "description": "Code review, quality analysis. Take 6 (gemini @hard 2026-05-10) showed reviewer-loop wedges as the residual class after persona changes closed the URL-guessing wedge — flash had trouble holding the rubric over a non-trivial Java diff. Bumped to pro primary so reviewer reasoning matches the leverage of the gate (one wrong approval costs 30+ minutes of downstream work).",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "gemini-flash"
        ]
      },
      "requirement_generation": {
        "description": "Requirement decomposition — partitioning a plan into reqs with non-overlapping file ownership + chain-dep DAG. Decomposition reasoning closer to architecture than to writing; gemini-flash variance (2 vs 4 reqs across runs 2026-05-05) confirms mid-tier is too thin. Pro preferred, flash fallback.",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "gemini-flash"
        ]
      },
      "scenario_generation": {
        "description": "BDD scenario generation",
        "preferred": [
          "gemini-flash"
        ]
      },
      "plan_review": {
        "description": "SOP-aware plan review. Plan-reviewer is the gate before execution — a wrong approval costs ~75min of execution wallclock for @hard. Bumped to pro primary 2026-05-10 alongside reviewing/qa: the gate reasons over goal/context/scope/requirements/scenarios in one pass and flash's discrimination at that span was at the edge in take 1 (two rejections + iter-3 approval).",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "gemini-flash"
        ]
      },
      "architecture": {
        "description": "Architecture generation — technology choices, component boundaries, data flow",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "gemini-flash"
        ]
      },
      "qa": {
        "description": "Rollup quality review — release-readiness verdict over the assembled plan. Fires once per plan; a false approval ships broken work past the human-in-loop gate. Bumped to pro primary 2026-05-10: cheapest insurance of the three review gates because qa runs only once per plan, not three times like plan-review.",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "gemini-flash"
        ]
      },
      "lesson_decomposition": {
        "description": "ADR-033 lesson decomposer — rare, benefits from a smarter model",
        "preferred": [
          "gemini-pro",
          "gemini-flash"
        ]
      },
      "fast": {
        "description": "Quick responses, classification",
        "preferred": [
          "gemini-flash"
        ]
      },
      "embedding": {
        "description": "Vector embeddings for graph entities (HTTP /v1/embeddings, NOT chat)",
        "preferred": [
          "semembed"
        ]
      },
      "query_classification": {
        "description": "graph-query T3 fallback classifier — small JSON output, latency-critical",
        "preferred": [
          "seminstruct-fast"
        ],
        "timeout": "10s"
      },
      "answer_synthesis": {
        "description": "graph-query globalSearch answer composition — ephemeral, agent reads once. Take 3 (gemini @hard 2026-05-10) wedged here: seminstruct-answer 1.7B-on-CPU hit 30s context-deadline-exceeded on real @hard queries (extractive composition over community summaries can be slower than the toy-fixture benchmark suggested). Mirroring community_summary's resolution: gemini-flash-lite primary (sub-second, Google's quality bar over the sub-7B floor) with seminstruct-answer kept as fallback for offline/quota scenarios.",
        "preferred": [
          "gemini-flash-lite"
        ],
        "fallback": [
          "seminstruct-answer"
        ],
        "timeout": "30s"
      },
      "community_summary": {
        "description": "graph-clustering community summarization — background batch, persisted into graph. seminstruct-8B-on-CPU validated 2026-05-06 ADR-036 Phase 2 to be too slow at any scale beyond toy fixtures (>180s per community on 2 CPUs). gemini-flash-lite gives sub-second response and Google's quality bar exceeds the MS GraphRAG sub-7B floor anyway. Local seminstruct-summary kept as fallback for offline/quota scenarios.",
        "preferred": [
          "gemini-flash-lite"
        ],
        "fallback": [
          "seminstruct-summary"
        ],
        "timeout": "300s"
      },
      "question_answering": {
        "description": "Answerer-agent backend for ask_question routes — bigger reasoning model than workflow default.",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "gemini-flash"
        ],
        "timeout": "60s"
      },
      "task_decomposition": {
        "description": "requirement-executor decomposer — DAG of executable nodes from a requirement. Planner-class reasoning, not coder-class generation.",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "gemini-flash"
        ]
      }
    },
    "defaults": {
      "model": "gemini-flash"
    }
  },
  "services": {
    "service-manager": {
      "name": "service-manager",
      "enabled": true,
      "config": {
        "http_port": 8080
      }
    },
    "component-manager": {
      "name": "component-manager",
      "enabled": true,
      "config": {}
    },
    "heartbeat": {
      "name": "heartbeat",
      "enabled": false,
      "config": {}
    },
    "message-logger": {
      "name": "message-logger",
      "enabled": true,
      "config": {
        "buffer_size": 10000,
        "monitor_subjects": [
          "user.>",
          "agent.>",
          "tool.>",
          "graph.>",
          "workflow.>",
          "source.>",
          "context.>"
        ]
      }
    }
  },
  "components": {
    "agentic-dispatch": {
      "name": "agentic-dispatch",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_role": "general",
        "default_model": "gemini-flash",
        "auto_continue": false,
        "stream_name": "USER",
        "permissions": {
          "view": [
            "*"
          ],
          "submit_task": [
            "*"
          ],
          "cancel_own": true,
          "cancel_any": [
            "admin"
          ],
          "approve": [
            "*"
          ]
        }
      }
    },
    "agentic-loop": {
      "name": "agentic-loop",
      "type": "processor",
      "enabled": true,
      "config": {
        "max_iterations": 75,
        "timeout": "900s",
        "stream_name": "AGENT",
        "loops_bucket": "AGENT_LOOPS",
        "content_bucket": "AGENT_CONTENT",
        "consumer": {
          "ack_wait": "720s",
          "heartbeat_interval": "240s"
        }
      }
    },
    "agentic-model": {
      "name": "agentic-model",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "timeout": "900s",
        "ports": {
          "inputs": [
            {
              "name": "agent.request",
              "type": "jetstream",
              "subject": "agent.request.>",
              "stream_name": "AGENT",
              "required": true,
              "config": {
                "ack_wait": "720s",
                "heartbeat_interval": "240s"
              }
            }
          ],
          "outputs": [
            {
              "name": "agent.response",
              "type": "jetstream",
              "subject": "agent.response.*",
              "stream_name": "AGENT",
              "required": true
            },
            {
              "name": "agent.stream",
              "type": "nats",
              "subject": "agent.stream.*",
              "required": false
            }
          ]
        }
      }
    },
    "agentic-tools": {
      "name": "agentic-tools",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "consumer_name_suffix": "semspec-e2e",
        "timeout": "180s"
      }
    },
    "graph-ingest": {
      "name": "graph-ingest",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entities_in",
              "subject": "graph.ingest.entity",
              "type": "jetstream",
              "stream_name": "GRAPH"
            }
          ],
          "outputs": [
            {
              "name": "entity_states",
              "subject": "ENTITY_STATES",
              "type": "kv-write"
            }
          ]
        },
        "enable_hierarchy": true
      }
    },
    "graph-index": {
      "name": "graph-index",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entity_watch",
              "subject": "ENTITY_STATES",
              "type": "kv-watch"
            }
          ],
          "outputs": [
            {
              "name": "outgoing_index",
              "subject": "OUTGOING_INDEX",
              "type": "kv"
            },
            {
              "name": "incoming_index",
              "subject": "INCOMING_INDEX",
              "type": "kv"
            },
            {
              "name": "alias_index",
              "subject": "ALIAS_INDEX",
              "type": "kv"
            },
            {
              "name": "predicate_index",
              "subject": "PREDICATE_INDEX",
              "type": "kv"
            }
          ]
        },
        "workers": 4,
        "batch_size": 50,
        "coalesce_ms": 100
      }
    },
    "graph-embedding": {
      "name": "graph-embedding",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entity_watch",
              "subject": "ENTITY_STATES",
              "type": "kv-watch"
            }
          ],
          "outputs": [
            {
              "name": "embeddings",
              "subject": "EMBEDDINGS_CACHE",
              "type": "kv"
            }
          ]
        },
        "embedder_type": "http",
        "batch_size": 50,
        "cache_ttl": "1h",
        "coalesce_ms": 200,
        "text_suffixes": [
          ".content",
          ".summary",
          ".description",
          ".title",
          ".name",
          ".goal",
          ".context",
          ".issue",
          ".suggestion",
          ".source_code",
          ".signature",
          ".body",
          ".comment"
        ]
      }
    },
    "graph-query": {
      "name": "graph-query",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "query_requests",
              "subject": "graph.query.>",
              "type": "nats-request"
            }
          ],
          "outputs": []
        },
        "request_timeout": "60s",
        "max_traversal_depth": 5,
        "max_traversal_nodes": 100
      }
    },
    "graph-gateway": {
      "name": "graph-gateway",
      "type": "gateway",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "http",
              "subject": ":8082",
              "type": "http"
            }
          ],
          "outputs": [
            {
              "name": "mutations",
              "subject": "graph.mutation.*",
              "type": "nats-request"
            }
          ]
        },
        "graphql_path": "/graphql",
        "mcp_path": "/mcp",
        "bind_address": ":8082",
        "enable_playground": true
      }
    },
    "planner": {
      "name": "planner",
      "type": "processor",
      "enabled": true,
      "config": {
        "max_generation_retries": 2,
        "sandbox_url": "http://sandbox:8090"
      }
    },
    "requirement-generator": {
      "name": "requirement-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_capability": "requirement_generation",
        "sandbox_url": "http://sandbox:8090"
      }
    },
    "scenario-generator": {
      "name": "scenario-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_capability": "scenario_generation"
      }
    },
    "architecture-generator": {
      "name": "architecture-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_capability": "architecture"
      }
    },
    "plan-manager": {
      "name": "plan-manager",
      "type": "processor",
      "enabled": true,
      "config": {
        "execution_bucket_name": "EXECUTION_STATES",
        "max_concurrent_planners": 3,
        "max_review_iterations": 3,
        "auto_approve": false,
        "default_capability": "planning",
        "auto_reject_on_exhaustion": true,
        "sandbox_url": "http://sandbox:8090"
      }
    },
    "plan-reviewer": {
      "name": "plan-reviewer",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_capability": "plan_review",
        "auto_approve": false,
        "sandbox_url": "http://sandbox:8090"
      }
    },
    "project-manager": {
      "name": "project-manager",
      "type": "processor",
      "enabled": true,
      "config": {
        "repo_path": "/workspace",
        "sandbox_url": "http://sandbox:8090"
      }
    },
    "scenario-orchestrator": {
      "name": "scenario-orchestrator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "scenario-orchestrator",
        "trigger_subject": "scenario.orchestrate.*",
        "execution_timeout": "3600s"
      }
    },
    "question-manager": {
      "name": "question-manager",
      "type": "processor",
      "enabled": true,
      "config": {}
    },
    "requirement-executor": {
      "name": "requirement-executor",
      "type": "processor",
      "enabled": true,
      "config": {
        "timeout_seconds": 3600,
        "sandbox_url": "http://sandbox:8090",
        "max_requirement_retries": 2,
        "max_decomposer_retries": 2
      }
    },
    "structural-validator": {
      "name": "structural-validator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "structural-validator",
        "repo_path": "/workspace",
        "checklist_path": ".semspec/checklist.json",
        "default_timeout": "900s",
        "sandbox_url": "http://sandbox:8090"
      }
    },
    "execution-manager": {
      "name": "execution-manager",
      "type": "processor",
      "enabled": true,
      "config": {
        "max_tdd_cycles": 7,
        "timeout_seconds": 3600,
        "sandbox_url": "http://sandbox:8090",
        "graph_gateway_url": "http://localhost:8082",
        "indexing_budget": "60s",
        "enable_positive_lessons": true
      }
    },
    "workflow-documents": {
      "name": "workflow-documents",
      "type": "output",
      "enabled": true,
      "config": {
        "plan_state_bucket": "PLAN_STATES"
      }
    },
    "plan-decision-handler": {
      "name": "plan-decision-handler",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "plan-decision-handler",
        "trigger_subject": "workflow.trigger.change-proposal-cascade",
        "accepted_subject": "workflow.events.change-proposal.accepted",
        "timeout_seconds": 120,
        "ports": {
          "inputs": [
            {
              "name": "cascade-triggers",
              "subject": "workflow.trigger.change-proposal-cascade",
              "type": "jetstream",
              "stream_name": "WORKFLOW",
              "description": "Receive cascade requests when a ChangeProposal is accepted",
              "required": true
            }
          ],
          "outputs": [
            {
              "name": "accepted-events",
              "subject": "workflow.events.change-proposal.accepted",
              "type": "jetstream",
              "stream_name": "WORKFLOW",
              "description": "Publish accepted event with cascade summary"
            },
            {
              "name": "cancellation-signals",
              "subject": "agent.signal.cancel.*",
              "type": "nats",
              "description": "Cancel running scenario loops affected by cascade"
            }
          ]
        }
      }
    },
    "qa-reviewer": {
      "name": "qa-reviewer",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_capability": "qa"
      }
    },
    "lesson-decomposer": {
      "name": "lesson-decomposer",
      "type": "processor",
      "enabled": true,
      "config": {
        "enabled": true,
        "stream_name": "WORKFLOW",
        "consumer_name": "lesson-decomposer",
        "filter_subject": "workflow.events.lesson.decompose.requested.>"
      }
    },
    "lesson-curator": {
      "name": "lesson-curator",
      "type": "processor",
      "enabled": true,
      "config": {
        "enabled": true,
        "sweep_interval": "24h",
        "idle_threshold": "720h",
        "min_age_before_retire": "168h"
      }
    },
    "graph-clustering": {
      "name": "graph-clustering",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entity_watch",
              "subject": "ENTITY_STATES",
              "type": "kv-watch",
              "description": "Watch entity state changes for batch trigger"
            }
          ],
          "outputs": [
            {
              "name": "communities",
              "subject": "COMMUNITY_INDEX",
              "type": "kv",
              "description": "Community detection results"
            }
          ]
        },
        "detection_interval": "30s",
        "batch_size": 100,
        "enable_llm": false,
        "min_community_size": 2,
        "max_iterations": 100,
        "enable_structural": true,
        "pivot_count": 16,
        "max_hop_distance": 10,
        "enable_anomaly_detection": true,
        "anomaly_config": {
          "enabled": true,
          "max_anomalies_per_run": 100,
          "core_anomaly": {
            "enabled": true,
            "min_core_level": 2
          },
          "semantic_gap": {
            "enabled": true,
            "similarity_threshold": 0.7,
            "min_structural_distance": 3
          },
          "virtual_edges": {
            "auto_apply": {
              "enabled": true,
              "min_confidence": 0.95,
              "predicate_template": "inferred.semantic.{band}"
            },
            "review_queue": {
              "enabled": true,
              "min_confidence": 0.7,
              "max_confidence": 0.95,
              "require_llm_classification": false
            }
          }
        }
      }
    }
  },
  "streams": {
    "USER": {
      "subjects": [
        "user.message.>",
        "user.response.>",
        "user.signal.>"
      ],
      "max_age": "1h",
      "storage": "memory",
      "replicas": 1
    },
    "AGENT": {
      "subjects": [
        "agent.task.>",
        "dev.task.>",
        "agent.request.>",
        "agent.response.>",
        "agent.signal.>",
        "agent.complete.>",
        "agent.created.>",
        "agent.failed.>",
        "agent.context.compaction.>",
        "context.build.>",
        "context.built.>",
        "tool.execute.>",
        "tool.result.>",
        "question.ask.>",
        "question.answer.>",
        "question.timeout.>",
        "question.escalate.>"
      ],
      "max_age": "24h",
      "storage": "memory",
      "replicas": 1
    },
    "GRAPH": {
      "subjects": [
        "graph.ingest.entity",
        "graph.ingest.batch",
        "graph.ingest.manifest",
        "graph.ingest.status",
        "graph.ingest.predicates",
        "graph.export.>"
      ],
      "max_age": "24h",
      "storage": "memory",
      "replicas": 1
    },
    "SOURCES": {
      "subjects": [
        "source.ingest.>",
        "source.status.>"
      ],
      "max_age": "24h",
      "storage": "memory",
      "replicas": 1
    },
    "WORKFLOW": {
      "subjects": [
        "workflow.trigger.>",
        "workflow.async.>",
        "workflow.result.>",
        "workflow.callback.>",
        "workflow.step.complete.>",
        "workflow.step.result.>",
        "workflow.events.>",
        "workflow.validate.>",
        "workflow.task.complete",
        "output.workflow.>",
        "proposal.request.>",
        "design.request.>",
        "spec.request.>",
        "tasks.request.>",
        "approve.request.>",
        "archive.request.>",
        "github.request.>",
        "scenario.orchestrate.>"
      ],
