        "repo_path": "/workspace",
        "checklist_path": ".semspec/checklist.json",
        "default_timeout": "120s",
        "sandbox_url": "http://sandbox:8090"
      }
    },
    "execution-manager": {
      "name": "execution-manager",
      "type": "processor",
      "enabled": true,
      "config": {
        "max_tdd_cycles": 3,
        "timeout_seconds": 300,
        "model": "mock-coder",
        "code_reviewer_model": "mock-code-reviewer",
        "sandbox_url": "http://sandbox:8090"
      }
    },
    "workflow-documents": {
      "name": "workflow-documents",
      "type": "output",
      "enabled": true,
      "config": {
        "plan_state_bucket": "PLAN_STATES"
      }
    },
    "plan-decision-handler": {
      "name": "plan-decision-handler",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "plan-decision-handler",
        "trigger_subject": "workflow.trigger.plan-decision-cascade",
        "accepted_subject": "workflow.events.plan-decision.accepted",
        "timeout_seconds": 120,
        "auto_accept_recovery": true,
        "ports": {
          "inputs": [
            {
              "name": "cascade-triggers",
              "subject": "workflow.trigger.plan-decision-cascade",
              "type": "jetstream",
              "stream_name": "WORKFLOW",
              "description": "Receive cascade requests when a ChangeProposal is accepted",
              "required": true
            }
          ],
          "outputs": [
            {
              "name": "accepted-events",
              "subject": "workflow.events.plan-decision.accepted",
              "type": "jetstream",
              "stream_name": "WORKFLOW",
              "description": "Publish accepted event with cascade summary"
            },
            {
              "name": "cancellation-signals",
              "subject": "agent.signal.cancel.*",
              "type": "nats",
              "description": "Cancel running scenario loops affected by cascade"
            }
          ]
        }
      }
    },
    "qa-reviewer": {
      "name": "qa-reviewer",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_capability": "qa"
      }
    },
    "lesson-decomposer": {
      "name": "lesson-decomposer",
      "type": "processor",
      "enabled": true,
      "config": {
        "enabled": true,
        "stream_name": "WORKFLOW",
        "consumer_name": "lesson-decomposer",
        "filter_subject": "workflow.events.lesson.decompose.requested.>"
      }
    },
    "lesson-curator": {
      "name": "lesson-curator",
      "type": "processor",
      "enabled": false,
      "config": {
        "enabled": false,
        "sweep_interval": "24h",
        "idle_threshold": "720h",
        "min_age_before_retire": "168h"
      }
    },
    "recovery-agent": {
      "name": "recovery-agent",
      "type": "processor",
      "enabled": true,
      "config": {
        "enabled": true,
        "stream_name": "WORKFLOW",
        "consumer_name": "recovery-agent",
        "filter_subject": "recovery.requested.>",
        "trajectory_step_limit": 80
      }
    }
  },
