{
  "_comment": "OpenRouter routes to many models behind one OpenAI-compatible endpoint. provider=openai; the BaseURL swap is the only required difference. HTTP-Referer/X-Title attribution headers (recommended by OpenRouter) are not yet wired through semstreams' agentic-model adapter — they're optional, not required for auth.",
  "_model_slugs": "Confirm the exact slug for your account's default at openrouter.ai/activity or with curl https://openrouter.ai/api/v1/models | jq. Common Qwen3 MoE candidates: qwen/qwen3-30b-a3b, qwen/qwen3-coder-30b-a3b-instruct.",
  "model_registry": {
    "endpoints": {
      "openrouter-qwen3-moe": {
        "provider": "openai",
        "url": "https://openrouter.ai/api/v1",
        "model": "qwen/qwen3.5-35b-a3b",
        "api_key_env": "OPENROUTER_API_KEY",
        "max_tokens": 32768,
        "supports_tools": true,
        "tool_format": "openai",
        "stream": false,
        "max_concurrent": 4,
        "requests_per_minute": 60
      },
      "openrouter-default": {
        "_comment": "Optional second endpoint pinned to whatever your account routes to as default. Useful if you want one alias for ad-hoc queries vs. one pinned to qwen3-30b-a3b for benchmarking.",
        "provider": "openai",
        "url": "https://openrouter.ai/api/v1",
        "model": "qwen/qwen3.5-35b-a3b",
        "api_key_env": "OPENROUTER_API_KEY",
        "max_tokens": 32768,
        "supports_tools": true,
        "tool_format": "openai",
        "stream": false,
        "max_concurrent": 4,
        "requests_per_minute": 60
      }
    },
    "capabilities": {
      "planning": {
        "description": "Plan generation and high-level reasoning",
