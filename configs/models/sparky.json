{
  "_comment": "Sparky is a friend's NVIDIA DGX Spark hosting Qwen3.6-27B-FP8 via vLLM, OpenAI-compatible API at http://genexergy.org:8000. Bearer auth via SPARKY_API_KEY env var. Dedicated single-GPU box — set max_concurrent low (2) to avoid choking on parallel agentic dispatch.",
  "_thinking_note": "qwen3.6-27b is reasoning-by-default. vLLM ignores reasoning_effort=none — the right knob is chat_template_kwargs.enable_thinking=false, which semstreams passes via endpoint.options. Without this, every reply burns 100-500 reasoning tokens before any content. Verified 2026-05-01 with direct probe: enable_thinking:false drops a math-question reply from 162 tokens to 2 tokens.",
  "model_registry": {
    "endpoints": {
      "sparky-qwen": {
        "provider": "openrouter",
        "url": "http://genexergy.org:8000/v1",
        "model": "qwen3.6-27b",
        "api_key_env": "SPARKY_API_KEY",
        "max_tokens": 131072,
        "max_output_tokens": 32000,
        "options": {
          "enable_thinking": false
        },
        "supports_tools": true,
        "tool_format": "openai",
        "stream": false,
        "max_concurrent": 2,
        "requests_per_minute": 120
      },
      "semembed": {
        "provider": "openai",
        "url": "http://semembed:8081/v1",
        "model": "Snowflake/snowflake-arctic-embed-s",
        "max_tokens": 0
      },
      "seminstruct-fast": {
        "provider": "openai",
        "url": "http://seminstruct-fast:8083/v1",
        "model": "qwen3-0.6b",
        "max_tokens": 4096,
        "max_output_tokens": 512,
        "supports_tools": false,
        "stream": false
      },
      "seminstruct-summary": {
        "provider": "openai",
        "url": "http://seminstruct-summary:8083/v1",
        "model": "qwen3-8b",
        "max_tokens": 16384,
        "max_output_tokens": 4096,
        "supports_tools": false,
        "stream": false
      }
    },
    "capabilities": {
      "planning": {
        "description": "Plan generation and high-level reasoning",
        "preferred": ["sparky-qwen"]
      },
      "writing": {
        "description": "Documentation, plans, specifications",
        "preferred": ["sparky-qwen"]
      },
      "coding": {
        "description": "Code generation, implementation",
        "preferred": ["sparky-qwen"]
      },
      "reviewing": {
        "description": "Code review, quality analysis",
        "preferred": ["sparky-qwen"]
      },
      "requirement_generation": {
        "description": "Requirement decomposition",
        "preferred": ["sparky-qwen"]
      },
      "scenario_generation": {
        "description": "BDD scenario generation",
        "preferred": ["sparky-qwen"]
      },
      "plan_review": {
        "description": "SOP-aware plan review",
        "preferred": ["sparky-qwen"]
      },
      "architecture": {
        "description": "Architecture generation",
        "preferred": ["sparky-qwen"]
      },
      "qa": {
        "description": "Rollup quality review",
        "preferred": ["sparky-qwen"]
      },
      "lesson_decomposition": {
        "description": "ADR-033 lesson decomposer",
        "preferred": ["sparky-qwen"]
      },
      "fast": {
        "description": "Quick responses, classification",
        "preferred": ["sparky-qwen"]
      },
      "embedding": {
        "description": "Vector embeddings for graph entities",
        "preferred": ["semembed"]
      },
      "query_classification": {
        "description": "graph-query T3 fallback classifier",
        "preferred": ["seminstruct-fast"],
        "timeout": "10s"
      },
      "answer_synthesis": {
        "description": "graph-query globalSearch answer composition",
        "preferred": ["seminstruct-summary"],
        "timeout": "30s"
      },
      "community_summary": {
        "description": "graph-clustering community summarization",
        "preferred": ["seminstruct-summary"],
        "timeout": "120s"
      }
    },
    "defaults": {
      "model": "sparky-qwen"
    }
  }
}
