{
  "version": "1.1.0",
  "persona_preset": "bmad",
  "platform": {
    "org": "semspec",
    "id": "semspec-dev",
    "environment": "dev"
  },
  "model_registry": {
    "capabilities": {
      "planning": {
        "description": "High-level reasoning, architecture decisions",
        "preferred": [
          "claude-opus",
          "claude-sonnet"
        ],
        "fallback": [
          "qwen3",
          "qwen"
        ]
      },
      "writing": {
        "description": "Documentation, proposals, specifications",
        "preferred": [
          "claude-sonnet"
        ],
        "fallback": [
          "qwen3",
          "qwen"
        ]
      },
      "coding": {
        "description": "Code generation, implementation",
        "preferred": [
          "claude-sonnet"
        ],
        "fallback": [
          "qwen",
          "qwen3"
        ]
      },
      "reviewing": {
        "description": "Code review, quality analysis",
        "preferred": [
          "claude-sonnet"
        ],
        "fallback": [
          "qwen3",
          "qwen"
        ]
      },
      "plan_review": {
        "description": "Strategic plan assessment, SOP compliance, completeness validation",
        "preferred": [
          "claude-opus",
          "claude-sonnet"
        ],
        "fallback": [
          "qwen3",
          "qwen"
        ]
      },
      "architecture": {
        "description": "Technology choices, component boundaries, deployment topology",
        "preferred": [
          "claude-opus",
          "claude-sonnet"
        ],
        "fallback": [
          "qwen3",
          "qwen"
        ]
      },
      "fast": {
        "description": "Quick responses, simple tasks",
        "preferred": [
          "claude-haiku"
        ],
        "fallback": [
          "qwen3-fast",
          "qwen"
        ]
      },
      "requirement_generation": {
        "description": "Requirement decomposition from plans",
        "preferred": [
          "claude-sonnet"
        ],
        "fallback": [
          "qwen3",
          "qwen"
        ]
      },
      "scenario_generation": {
        "description": "BDD scenario generation from requirements",
        "preferred": [
          "claude-sonnet"
        ],
        "fallback": [
          "qwen3",
          "qwen"
        ]
      },
      "qa": {
        "description": "QA rollup review, integration validation, cross-requirement testing",
        "preferred": [
          "claude-sonnet"
        ],
        "fallback": [
          "qwen3",
          "qwen"
        ]
      }
    },
    "endpoints": {
      "claude-opus": {
        "provider": "anthropic",
        "model": "claude-opus-4-6",
        "max_tokens": 200000,
        "supports_tools": true,
        "tool_format": "anthropic",
        "max_concurrent": 5,
        "requests_per_minute": 50,
        "request_timeout": "300s"
      },
      "claude-sonnet": {
        "provider": "anthropic",
        "model": "claude-sonnet-4-6",
        "max_tokens": 200000,
        "supports_tools": true,
        "tool_format": "anthropic",
        "max_concurrent": 10,
        "requests_per_minute": 100,
        "request_timeout": "300s"
      },
      "claude-haiku": {
        "provider": "anthropic",
        "model": "claude-haiku-4-5-20251001",
        "max_tokens": 200000,
        "supports_tools": true,
        "tool_format": "anthropic",
        "max_concurrent": 10,
        "requests_per_minute": 200,
        "request_timeout": "300s"
      },
      "qwen": {
        "provider": "ollama",
        "url": "${LLM_API_URL:-http://localhost:11434}/v1",
        "model": "qwen3-coder:30b",
        "max_tokens": 131072,
        "supports_tools": true,
        "tool_format": "openai",
        "max_concurrent": 1
      },
      "qwen3": {
        "provider": "ollama",
        "url": "${LLM_API_URL:-http://localhost:11434}/v1",
        "model": "qwen3:14b",
        "max_tokens": 32768,
        "supports_tools": true,
        "max_concurrent": 1
      },
      "qwen3-fast": {
        "provider": "ollama",
        "url": "${LLM_API_URL:-http://localhost:11434}/v1",
        "model": "qwen3:1.7b",
        "max_tokens": 32768,
        "supports_tools": true,
        "max_concurrent": 2
      },
      "ollama-coder": {
        "provider": "ollama",
        "url": "${LLM_API_URL:-http://localhost:11434}/v1",
        "model": "qwen2.5-coder:7b",
        "max_tokens": 32768,
        "supports_tools": true,
        "max_concurrent": 1
      }
    },
    "defaults": {
      "model": "qwen",
      "max_concurrent_global": 10
    }
  },
  "nats": {
    "urls": [
      "${NATS_URL:-nats://localhost:4222}"
    ],
    "max_reconnects": -1,
    "reconnect_wait": "2s",
    "jetstream": {
      "enabled": true
    }
  },
  "services": {
    "service-manager": {
      "name": "service-manager",
      "enabled": true,
      "config": {
        "http_port": 8080
      }
    },
    "component-manager": {
      "name": "component-manager",
      "enabled": true,
      "config": {}
    },
    "heartbeat": {
      "name": "heartbeat",
      "enabled": false,
      "config": {}
    },
    "message-logger": {
      "name": "message-logger",
      "enabled": true,
      "config": {
        "buffer_size": 10000,
        "monitor_subjects": [
          "user.>",
          "agent.>",
          "tool.>",
          "graph.>",
          "context.>",
          "workflow.>",
          "source.>"
        ]
      }
    }
  },
  "components": {
    "agentic-dispatch": {
      "name": "agentic-dispatch",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_role": "general",
        "default_model": "qwen",
        "auto_continue": false,
        "stream_name": "USER",
        "permissions": {
          "view": [
            "*"
          ],
          "submit_task": [
            "*"
          ],
          "cancel_own": true,
          "cancel_any": [
            "admin"
          ],
          "approve": [
            "*"
          ]
        }
      }
    },
    "agentic-loop": {
      "name": "agentic-loop",
      "type": "processor",
      "enabled": true,
      "config": {
        "max_iterations": 50,
        "timeout": "1800s",
        "stream_name": "AGENT",
        "loops_bucket": "AGENT_LOOPS",
        "content_bucket": "AGENT_CONTENT",
        "consumer": {
          "ack_wait": "5m",
          "heartbeat_interval": "2m"
        },
        "context": {
          "summarization_model": "fast"
        }
      }
    },
    "agentic-model": {
      "name": "agentic-model",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "timeout": "1800s"
      }
    },
    "agentic-tools": {
      "name": "agentic-tools",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "consumer_name_suffix": "semspec"
      }
    },
    "question-manager": {
      "name": "question-manager",
      "type": "processor",
      "enabled": true,
      "config": {}
    },
    "requirement-generator": {
      "name": "requirement-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_capability": "requirement_generation"
      }
    },
    "architecture-generator": {
      "name": "architecture-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_capability": "architecture"
      }
    },
    "scenario-generator": {
      "name": "scenario-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_capability": "scenario_generation"
      }
    },
    "planner": {
      "name": "planner",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_capability": "planning",
        "max_generation_retries": 2
      }
    },
    "plan-reviewer": {
      "name": "plan-reviewer",
      "type": "processor",
      "enabled": true,
      "config": {
        "llm_timeout": "120s",
        "default_capability": "plan_review"
      }
    },
    "project-manager": {
      "name": "project-manager",
      "type": "processor",
      "enabled": true,
      "config": {
        "repo_path": "${SEMSPEC_REPO_PATH:-}",
        "sandbox_url": "${SANDBOX_URL:-}"
      }
    },
    "plan-manager": {
      "name": "plan-manager",
      "type": "processor",
      "enabled": true,
      "config": {
        "execution_bucket_name": "EXECUTION_STATES",
        "sandbox_url": "${SANDBOX_URL:-}",
        "max_concurrent_planners": 3,
        "max_review_iterations": 3,
        "auto_approve": true,
        "auto_approve_review": true,
        "timeout_seconds": 1800,
        "model": "default",
        "default_capability": "planning"
      }
    },
    "workflow-validator": {
      "name": "workflow-validator",
      "type": "processor",
      "enabled": true,
      "config": {
        "timeout_secs": 30
      }
    },
    "structural-validator": {
      "name": "structural-validator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "structural-validator",
        "checklist_path": ".semspec/checklist.json",
        "default_timeout": "120s",
        "sandbox_url": "${SANDBOX_URL:-}"
      }
    },
    "workflow-documents": {
      "name": "workflow-documents",
      "type": "output",
      "enabled": true,
      "config": {
        "plan_state_bucket": "PLAN_STATES"
      }
    },
    "execution-manager": {
      "name": "execution-manager",
      "type": "processor",
      "enabled": true,
      "config": {
        "sandbox_url": "${SANDBOX_URL:-}",
        "graph_gateway_url": "${GRAPH_GATEWAY_URL:-}",
        "indexing_budget": "60s",
        "max_tdd_cycles": 3,
        "timeout_seconds": 1800,
        "model": "default",
        "ports": {
          "inputs": [
            {
              "name": "execution-trigger",
              "subject": "workflow.trigger.task-execution-loop",
              "type": "jetstream",
              "stream_name": "WORKFLOW",
              "description": "Receive task execution triggers from task-dispatcher",
              "required": true
            },
            {
              "name": "loop-completions",
              "subject": "agentic.loop_completed.v1",
              "type": "jetstream",
              "stream_name": "AGENT",
              "description": "Receive agentic loop completion events",
              "required": true
            }
          ],
          "outputs": [
            {
              "name": "entity-triples",
              "subject": "graph.mutation.triple.add",
              "type": "nats",
              "description": "Publish entity state triples",
              "required": false
            },
            {
              "name": "agent-tasks",
              "subject": "agent.task.>",
              "type": "nats",
              "description": "Dispatch agent tasks",
              "required": false
            }
          ]
        }
      }
    },
    "rollup-reviewer": {
      "name": "rollup-reviewer",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_capability": "qa",
        "skip_review": false
      }
    },
    "scenario-orchestrator": {
      "name": "scenario-orchestrator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "scenario-orchestrator",
        "trigger_subject": "scenario.orchestrate.*",
        "workflow_trigger_subject": "workflow.trigger.requirement-execution-loop",
        "execution_timeout": "3600s",
        "max_concurrent": 5,
        "ports": {
          "inputs": [
            {
              "name": "orchestration-triggers",
              "subject": "scenario.orchestrate.*",
              "type": "jetstream",
              "stream_name": "WORKFLOW",
              "description": "Receive scenario orchestration triggers",
              "required": true
            }
          ],
          "outputs": [
            {
              "name": "requirement-execution-triggers",
              "subject": "workflow.trigger.requirement-execution-loop",
              "type": "nats",
              "description": "Trigger requirement-executor for each ready requirement"
            }
          ]
        }
      }
    },
    "requirement-executor": {
      "name": "requirement-executor",
      "type": "processor",
      "enabled": true,
      "config": {
        "timeout_seconds": 3600,
        "model": "default",
        "sandbox_url": "${SANDBOX_URL:-}",
        "max_requirement_retries": 2,
        "ports": {
          "inputs": [
            {
              "name": "requirement-trigger",
              "subject": "workflow.trigger.requirement-execution-loop",
              "type": "jetstream",
              "stream_name": "WORKFLOW",
              "description": "Receive requirement execution triggers from scenario-orchestrator",
              "required": true
            },
            {
              "name": "loop-completions",
              "subject": "agentic.loop_completed.v1",
              "type": "jetstream",
              "stream_name": "AGENT",
              "description": "Receive agentic loop completion events",
              "required": true
            }
          ],
          "outputs": [
            {
              "name": "entity-triples",
              "subject": "graph.mutation.triple.add",
              "type": "nats",
              "description": "Publish entity state triples"
            },
            {
              "name": "agent-tasks",
              "subject": "agent.task.>",
              "type": "nats",
              "description": "Dispatch agent tasks for decomposition and node execution"
            }
          ]
        }
      }
    },
    "change-proposal-handler": {
      "name": "change-proposal-handler",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "change-proposal-handler",
        "trigger_subject": "workflow.trigger.change-proposal-cascade",
        "accepted_subject": "workflow.events.change-proposal.accepted",
        "timeout_seconds": 120,
        "ports": {
          "inputs": [
            {
              "name": "cascade-triggers",
              "subject": "workflow.trigger.change-proposal-cascade",
              "type": "jetstream",
              "stream_name": "WORKFLOW",
              "description": "Receive cascade requests when a ChangeProposal is accepted",
              "required": true
            }
          ],
          "outputs": [
            {
              "name": "accepted-events",
              "subject": "workflow.events.change-proposal.accepted",
              "type": "jetstream",
              "stream_name": "WORKFLOW",
              "description": "Publish accepted event with cascade summary"
            },
            {
              "name": "cancellation-signals",
              "subject": "agent.signal.cancel.*",
              "type": "nats",
              "description": "Cancel running scenario loops affected by cascade"
            }
          ]
        }
      }
    },
    "graph-ingest": {
      "name": "graph-ingest",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entities_in",
              "subject": "graph.ingest.entity",
              "type": "jetstream",
              "stream_name": "GRAPH"
            }
          ],
          "outputs": [
            {
              "name": "entity_states",
              "subject": "ENTITY_STATES",
              "type": "kv-write"
            }
          ]
        },
        "enable_hierarchy": true
      }
    },
    "graph-index": {
      "name": "graph-index",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entity_watch",
              "subject": "ENTITY_STATES",
              "type": "kv-watch"
            }
          ],
          "outputs": [
            {
              "name": "outgoing_index",
              "subject": "OUTGOING_INDEX",
              "type": "kv"
            },
            {
              "name": "incoming_index",
              "subject": "INCOMING_INDEX",
              "type": "kv"
            },
            {
              "name": "alias_index",
              "subject": "ALIAS_INDEX",
              "type": "kv"
            },
            {
              "name": "predicate_index",
              "subject": "PREDICATE_INDEX",
              "type": "kv"
            }
          ]
        },
        "workers": 2,
        "batch_size": 50,
        "coalesce_ms": 100
      }
    },
    "graph-embedding": {
      "name": "graph-embedding",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entity_watch",
              "subject": "ENTITY_STATES",
              "type": "kv-watch"
            }
          ],
          "outputs": [
            {
              "name": "embeddings",
              "subject": "EMBEDDINGS_CACHE",
              "type": "kv"
            }
          ]
        },
        "embedder_type": "${EMBED_TYPE:-bm25}",
        "batch_size": 50,
        "cache_ttl": "1h",
        "coalesce_ms": 200,
        "text_suffixes": [
          ".content",
          ".summary",
          ".description",
          ".title",
          ".name",
          ".goal",
          ".context",
          ".issue",
          ".suggestion",
          ".source_code",
          ".signature",
          ".body"
        ]
      }
    },
    "graph-query": {
      "name": "graph-query",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "query_requests",
              "subject": "graph.query.>",
              "type": "nats-request"
            }
          ],
          "outputs": []
        },
        "request_timeout": "5s",
        "max_traversal_depth": 5,
        "max_traversal_nodes": 100
      }
    },
    "graph-gateway": {
      "name": "graph-gateway",
      "type": "gateway",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "http",
              "subject": ":8082",
              "type": "http"
            }
          ],
          "outputs": [
            {
              "name": "mutations",
              "subject": "graph.mutation.*",
              "type": "nats-request"
            }
          ]
        },
        "graphql_path": "/graphql",
        "mcp_path": "/mcp",
        "bind_address": ":8082",
        "enable_playground": true
      }
    }
  },
  "streams": {
    "AGENT": {
      "subjects": [
        "agent.task.>",
        "dev.task.>",
        "agent.request.>",
        "agent.response.>",
        "agent.signal.>",
        "agent.complete.>",
        "agent.created.>",
        "agent.failed.>",
        "agent.context.compaction.>",
        "agentic.>",
        "tool.execute.>",
        "tool.result.>",
        "question.ask.>",
        "question.answer.>",
        "question.timeout.>",
        "question.escalate.>",
        "context.build.>",
        "context.built.>"
      ],
      "max_age": "24h",
      "storage": "memory",
      "replicas": 1
    },
    "GRAPH": {
      "subjects": [
        "graph.ingest.entity",
        "graph.ingest.batch",
        "graph.ingest.manifest",
        "graph.ingest.status",
        "graph.ingest.predicates",
        "graph.export.>"
      ],
      "max_age": "24h",
      "storage": "memory",
      "replicas": 1
    },
    "WORKFLOW": {
      "subjects": [
        "workflow.trigger.>",
        "workflow.async.>",
        "workflow.result.>",
        "workflow.callback.>",
        "workflow.step.complete.>",
        "workflow.step.result.>",
        "workflow.events.>",
        "workflow.validate.>",
        "workflow.task.complete",
        "output.workflow.>",
        "proposal.request.>",
        "design.request.>",
        "spec.request.>",
        "tasks.request.>",
        "approve.request.>",
        "archive.request.>",
        "github.request.>",
        "change-proposal.request.>",
        "scenario.orchestrate.>"
      ],
      "max_age": "24h",
      "storage": "memory",
      "replicas": 1
    },
    "USER": {
      "subjects": [
        "user.message.>",
        "user.response.>",
        "user.signal.>"
      ],
      "max_age": "1h",
      "storage": "memory",
      "replicas": 1
    },
    "SOURCES": {
      "subjects": [
        "source.ingest.>",
        "source.status.>"
      ],
      "max_age": "24h",
      "storage": "memory",
      "replicas": 1
    }
  }
}
