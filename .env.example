# Semspec Environment Configuration
# Copy to .env and uncomment the variables you need:
#   cp .env.example .env
#
# The Taskfile loads .env automatically (dotenv: ['.env']).
# Docker Compose also loads .env by default.

# ─── LLM Provider Keys ───────────────────────────────────────────────
# Set at least one for cloud LLM. Without any, semspec falls back to
# local Ollama at LLM_API_URL.

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI / OpenRouter (OpenAI-compatible)
# OPENAI_API_KEY=sk-or-...

# Google AI Studio (Gemini) — used via OpenAI-compatible endpoint
# GEMINI_API_KEY=AIza...

# ─── Optional Services ───────────────────────────────────────────────

# Brave Search API — enables the web_search tool for agents
# BRAVE_SEARCH_API_KEY=BSA...

# ─── Infrastructure ──────────────────────────────────────────────────

# Ollama URL (default: http://localhost:11434)
# Inside Docker, the compose file overrides this to http://host.docker.internal:11434
# LLM_API_URL=http://localhost:11434

# NATS URL (default: nats://localhost:4222)
# Only needed when running the binary outside Docker against a non-default NATS.
# NATS_URL=nats://localhost:4222

# ─── Docker Compose ──────────────────────────────────────────────────

# Path to the project you want agents to work on.
# Mounted into the sandbox (read-write) and semsource (read-only).
# Defaults to "." (the semspec repo itself) if unset.
# SEMSPEC_REPO=/path/to/your/project

# File ownership inside the sandbox container.
# Set these if files created by agents have wrong permissions on your host.
# Run: echo "SANDBOX_UID=$(id -u)" >> .env && echo "SANDBOX_GID=$(id -g)" >> .env
# SANDBOX_UID=1000
# SANDBOX_GID=1000

# ─── Debugging ────────────────────────────────────────────────────────

# Log level for semspec and semsource (debug, info, warn, error)
# LOG_LEVEL=info
