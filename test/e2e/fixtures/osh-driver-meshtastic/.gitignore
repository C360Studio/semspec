# /sources/ is the read-only mount of semsource clones — reference material
# only. The agent never copies content from /sources/ into the worktree,
# but if a tool or command accidentally writes a `sources/` directory
# inside the workspace, this entry keeps it out of commits.
sources/

# Standard Java/Gradle build artefacts.
.gradle/
build/
*.class
*.jar
*.war
# Re-include the Gradle Wrapper jar — convention is to commit it so
# contributors don't need Gradle pre-installed. Without this negation
# the *.jar pattern above silently excludes the wrapper, which makes
# `./gradlew` fall through to "gradle: command not found" or trigger a
# slow-bootstrap-from-zip wedge (caught take 4 2026-05-10).
!gradle/wrapper/gradle-wrapper.jar

# IDE noise.
.idea/
*.iml
.vscode/
.classpath
.project
.settings/
