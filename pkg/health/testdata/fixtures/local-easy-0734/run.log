task: [e2e:reset-fixtures] for fixture in test/e2e/fixtures/go-project test/e2e/fixtures/hello-world-py test/e2e/fixtures/osh-driver-meshtastic; do
  if [ ! -d "$fixture/.git" ]; then
    continue
  fi
  ROOT=$(git -C "$fixture" rev-list --max-parents=0 HEAD 2>/dev/null | head -1)
  if [ -z "$ROOT" ]; then
    echo "[RESET-FIXTURES] $fixture has no commits — skipping"
    continue
  fi
  echo "[RESET-FIXTURES] $fixture -> $ROOT"
  # Force main to the root commit and switch to it, drop unstaged +
  # untracked (but keep ignored), then prune every accumulated
  # agent/* + semspec/* branch the agents created. The previous
  # inline pattern only reset whichever branch HEAD happened to be
  # on, leaving cross-run drift on main and other branches.
  # `checkout -f` is required because prior runs leave the working
  # tree dirty (modified main.go, untracked main_test.go, etc.) —
  # without -f the switch aborts.
  git -C "$fixture" checkout -q -f -B main "$ROOT"
  git -C "$fixture" reset --hard -q "$ROOT"
  # Clean untracked agent files (main_test.go, health.go, etc.) but
  # exclude .semspec/ — that directory holds files tracked by the
  # PARENT semspec repo (e.g. hello-world-py/.semspec/checklist.json
  # is committed to /Users/.../semspec, not to the fixture's own
  # nested .git). Without the exclude, `git clean -fd` from the
  # fixture's git sees those parent-tracked files as untracked and
  # deletes them, leaving the parent repo with a phantom `D` in
  # `git status`. Caught 2026-04-29 — see project_reset_fixtures_amnesty.
  # The explicit `rm -rf` below handles known runtime cruft inside
  # .semspec/.
  git -C "$fixture" clean -fd -q -e .semspec/
  # Remove the .semspec/worktrees/ directory so `git worktree prune`
  # forgets the worktrees the agents created during prior runs. Then
  # branch -D works because no worktree pins the ref anymore.
  # `--expire=now` is required because the default expiry is 3 hours;
  # without it, prune leaves recent stale entries in place and the
  # subsequent branch-delete fails with "branch in use by worktree".
  rm -rf "$fixture/.semspec/worktrees" "$fixture/.semspec/plans" 2>/dev/null || true
  git -C "$fixture" worktree prune --expire=now -q 2>/dev/null || true
  git -C "$fixture" for-each-ref --format='%(refname:short)' refs/heads | grep -vE '^main$' | while read -r b; do
    git -C "$fixture" branch -D -q "$b" 2>/dev/null || true
  done
done
