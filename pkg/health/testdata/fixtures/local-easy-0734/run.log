[UI:TEST:LLM] Running @easy Playwright tests...
task: [e2e:ui:test:llm] cd ui
# Provider-specific timeouts for real LLM E2E tests.
# Local Ollama is slower than cloud providers — bump cascade + execution.
# Claude needs the longest — plan review rejections add full revision cycles.
if [ "local" = "claude" ]; then
  CASCADE_TIMEOUT=900000 EXECUTION_TIMEOUT=3600000 PLAYWRIGHT_TIMEOUT=3600000 \
    npx playwright test --grep @easy --project t2 --no-deps
elif [ "local" = "local" ]; then
  CASCADE_TIMEOUT=1200000 EXECUTION_TIMEOUT=2400000 PLAYWRIGHT_TIMEOUT=2400000 \
    npx playwright test --grep @easy --project t2 --no-deps
else
  PLAYWRIGHT_TIMEOUT=1200000 \
    npx playwright test --grep @easy --project t2 --no-deps
fi


