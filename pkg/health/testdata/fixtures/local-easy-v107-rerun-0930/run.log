task: [e2e:check-ports:ui] echo "[CHECK] Verifying UI E2E ports are available..."
STALE=false
for port in 3000 4223 8223 11534; do
  if lsof -Pi :$port -sTCP:LISTEN -t >/dev/null 2>&1; then
    STALE=true
    break
  fi
done
if [ "$STALE" = "true" ]; then
  echo "[CHECK] Stale UI containers detected — auto-cleaning..."
  docker compose -p semspec-ui-e2e -f ui/docker-compose.e2e.yml down -v --timeout 5 2>/dev/null || true
  docker ps -a --filter name=semspec-ui-e2e --format "" | xargs -r docker rm -f 2>/dev/null || true
  sleep 2
  for port in 3000 4223 8223 11534; do
    if lsof -Pi :$port -sTCP:LISTEN -t >/dev/null 2>&1; then
      echo "[ERROR] Port $port still in use after cleanup."
      exit 1
    fi
  done
  echo "[OK] Stale UI containers cleaned, ports now available"
else
  echo "[OK] All UI E2E ports available (3000, 4223, 8223, 11534)"
fi

