{
  "namespace": "semspec",
  "mode": "headless",
  "sources": [
    {
      "type": "git",
      "url": "/workspace",
      "branch": "main",
      "poll_interval": "10s",
      "watch": true
    },
    {
      "type": "ast",
      "path": "/workspace",
      "language": "go",
      "index_interval": "10s",
      "watch": true
    },
    {
      "type": "docs",
      "paths": ["/workspace"],
      "watch": true
    },
    {
      "type": "config",
      "paths": ["/workspace"],
      "watch": true
    }
  ]
}
